      },
      "font-size": {
        "$type": "dimension",
        "$value": "14px"
      },
      "font-weight": {
        "$type": "number",
        "$value": 400
      },
      "line-height": {
        "$type": "dimension",
        "$value": "18px"
      },
      "letter-spacing": {
        "$type": "dimension",
        "$value": "0.16px"
      }
    }
