          "$value": "#eff2f5"
        },
        "active": {
          "$type": "color",
          "$value": "#e6eaef"
        }
      },
      "outline": {
        "background": {
          "$type": "color",
          "$value": "#f6f8fa"
        },
        "hover": {
          "$type": "color",
          "$value": "#0969da"
        },
        "active": {
          "$type": "color",
          "$value": "#0757ba"
        },
        "foreground": {
          "$type": "color",
          "$value": "#0969da"
        }
      },
      "danger": {
        "background": {
          "$type": "color",
          "$value": "#f6f8fa"
        },
        "hover": {
          "$type": "color",
          "$value": "#cf222e"
        },
        "active": {
          "$type": "color",
          "$value": "#a40e26"
        },
        "foreground": {
          "$type": "color",
          "$value": "#d1242f"
